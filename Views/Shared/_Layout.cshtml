<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RutaSegura</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RutaSeguraMvc.styles.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <header class="topbar">
            <div class="brand">
                <span class="brand-icon">RS</span>
                <span>RutaSegura</span>
            </div>

            <nav class="nav-links">
                <a asp-area="" asp-controller="Dashboard" asp-action="Index">Inicio</a>
                <a asp-area="" asp-controller="Reportes" asp-action="Index">Reportes</a>
                <a asp-area="" asp-controller="Contactos" asp-action="Index">Contactos</a>
                <a asp-area="" asp-controller="Catalogos" asp-action="Index">Catálogo</a>
                <partial name="_LoginPartial" />
            </nav>
        </header>
    }

    <main class="page-container">
        @RenderBody()
    </main>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <footer class="footer">
            RutaSegura © 2026
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>